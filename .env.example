# Optional: add a real OpenWeatherMap API key to fetch live weather.
# Without this value, the app uses realistic mock weather so reviewers can run it immediately.
NEXT_PUBLIC_OPENWEATHER_API_KEY=

# Optional: add a Google OAuth Web Client ID to enable Sign in with Google on the login page.
# Configure the app origin in Google Cloud Console under Authorized JavaScript origins.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
